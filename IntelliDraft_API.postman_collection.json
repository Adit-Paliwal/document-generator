      ]
    },
    {
      "name": "⚡ Generation",
      "item": [
        {
          "name": "Generate from Project (Recommended)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/generate/project/{{project_id}}",
            "description": "Start document generation from a saved project. No body needed. Returns job_id.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Has job_id', () => pm.expect(json).to.have.property('job_id'));",
                  "if (json.job_id) {",
                  "  pm.collectionVariables.set('job_id', json.job_id);",
                  "  console.log('Saved job_id:', json.job_id);",
                  "  console.log('Sections queued:', json.sections.length);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate from Document (Legacy)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/generate/start",
            "description": "Start generation directly from document + user inputs (without a saved project).",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"document_id\": \"{{document_id}}\",\n  \"user_inputs\": {\n    \"project_name\": \"Smart Meter Analytics\",\n    \"document_type\": \"BRD\",\n    \"output_format\": \"Word (.docx)\",\n    \"stakeholders\": \"Ravi Kumar (PM), Priya Sharma (BA)\",\n    \"project_description\": \"IoT smart meter analytics platform for AESL.\",\n    \"business_problem\": \"Manual meter reading is costly and error-prone.\",\n    \"expected_outcome\": \"Real-time meter data with automated billing.\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.job_id) pm.collectionVariables.set('job_id', json.job_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Poll Job Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/generate/{{job_id}}",
            "description": "Poll every 3s to track progress. Check section statuses: pending → running → completed/failed."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const sections = json.sections || [];",
                  "const done = sections.filter(s => s.status === 'completed').length;",
                  "const total = sections.length;",
                  "console.log(`Job status: ${json.status} | Sections: ${done}/${total} done`);",
                  "if (sections.length > 0) {",
                  "  pm.collectionVariables.set('section_id', sections[0].section_id);",
                  "  console.log('Saved section_id:', sections[0].section_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Single Section",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/generate/{{job_id}}/section/{{section_id}}",
            "description": "Get full section with all versions and comments."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "console.log('Section:', json.section_title, '| Status:', json.status, '| Versions:', (json.versions||[]).length);"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Comment to Section",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/generate/{{job_id}}/section/{{section_id}}/comment",
            "description": "Add a user review comment. Save the returned comment_id for regenerate.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment_text\": \"Please make this section more concise and add specific metrics.\",\n  \"comment_type\": \"edit_request\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.comment && json.comment.comment_id) {",
                  "  pm.collectionVariables.set('comment_id', json.comment.comment_id);",
                  "  console.log('Saved comment_id:', json.comment.comment_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Regenerate Section",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/generate/{{job_id}}/section/{{section_id}}/regenerate",
            "description": "Regenerate section incorporating the comment. Creates a new version.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment_id\": \"{{comment_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('New version created', () => pm.expect(json.new_version.version_number).to.be.above(1));",
                  "console.log('New version number:', json.new_version.version_number);"
                ]
              }
            }
          ]
        },
        {
          "name": "Accept Section Version",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/generate/{{job_id}}/section/{{section_id}}/accept",
            "description": "Accept a specific version. This version will be used in the final export.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version_number\": 1\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Export Document (DOCX)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/generate/{{job_id}}/export?format=docx",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "generate",
                "{{job_id}}",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "docx",
                  "description": "docx | pdf | md"
                }
              ]
            },
            "description": "Download the assembled document. Change format= to pdf or md if needed."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is file download', () => pm.expect(pm.response.headers.get('Content-Disposition')).to.include('attachment'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "📐 Templates",
      "item": [
        {
          "name": "List Templates",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/templates",
              "host": [
