{
  "info": {
    "name": "IntelliDraft API",
    "description": "Complete API collection for IntelliDraft — document ingestion, project management, AI field derivation, and document generation.\n\n**Base URL:** http://localhost:7071/api\n\n**How to use:**\n1. Set the `base_url` variable to your server URL\n2. Run requests in the order shown (upload → extract → create project → generate)\n3. Use the Tests tab on each request to auto-capture IDs into collection variables",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:7071/api",
      "type": "string"
    },
    {
      "key": "document_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "project_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "job_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "section_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "comment_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "⚙️ System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Lightweight liveness probe. Zero DB cost. Returns immediately."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        },
        {
          "name": "API Docs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/docs",
            "description": "Opens the interactive API reference HTML page."
          }
        }
      ]
    },
    {
      "name": "📄 Ingestion",
      "item": [
        {
          "name": "Get Form Fields",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/form-fields",
            "description": "Returns all form field definitions for the Create Project form."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has fields array', () => pm.expect(pm.response.json()).to.have.property('fields'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/upload",
            "description": "Upload a PPTX/DOCX/PDF/XLSX file. Returns document_id saved as collection variable.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "Select your PPTX, DOCX, PDF, or XLSX file here"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Has document_id', () => pm.expect(json).to.have.property('document_id'));",
                  "if (json.document_id) {",
                  "  pm.collectionVariables.set('document_id', json.document_id);",
                  "  console.log('Saved document_id:', json.document_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Document",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/document/{{document_id}}",
            "description": "Get full parsed document metadata. Uses document_id from Upload."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Document Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/document/{{document_id}}/status",
            "description": "Get lightweight document status."
          }
        }
      ]
    },
    {
      "name": "🗂 Projects",
      "item": [
        {
          "name": "Extract Project Data (AI)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/extract-project-data",
            "description": "AI Populate button. Reads uploaded document and extracts all 15 project form fields. Takes 30-60s. Returns extracted{} wrapper + missing_required list.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"document_ids\": [\n    \"{{document_id}}\"\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has extracted object', () => pm.expect(json).to.have.property('extracted'));",
                  "pm.test('Has missing_required array', () => pm.expect(json).to.have.property('missing_required'));",
                  "const ex = json.extracted || {};",
                  "console.log('Filled fields:', Object.keys(ex).filter(k => ex[k] !== null).join(', '));",
                  "console.log('Missing required:', json.missing_required.map(f => f.field).join(', ') || 'none');"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects",
            "description": "Save project to DB. All 12 marked fields are required. Returns project_id.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"business_unit\": \"AESL\",\n  \"project_name\": \"Smart Meter Analytics\",\n  \"project_code\": \"AESL-2025-042\",\n  \"problem_statement\": \"Manual meter reading is error-prone and costly, leading to billing disputes.\",\n  \"project_objective\": \"Automate meter data collection with real-time analytics dashboard.\",\n  \"stakeholders\": [\n    {\n      \"name\": \"Srinivas Gutta\",\n      \"designation\": \"Project Manager\"\n    },\n    {\n      \"name\": \"Ali Imam\",\n      \"designation\": \"Technical Lead\"\n    }\n  ],\n  \"start_date\": \"2025-04-01\",\n  \"end_date\": \"2025-12-31\",\n  \"as_is_processes\": \"Field engineers visit each meter monthly for manual reading and log results in spreadsheets.\",\n  \"proposed_solution\": \"Deploy IoT smart meters with a central analytics platform integrated with SAP.\",\n  \"technical_landscape\": \"Azure IoT Hub, Power BI, SAP ERP integration via REST API.\",\n  \"business_priority\": \"Critical\",\n  \"constraints\": \"Budget capped at 5 Crores. No disruption to existing billing cycle.\",\n  \"risks\": \"Device connectivity in remote areas. Data privacy regulations.\",\n  \"estimated_cost_crores\": \"4.5\",\n  \"document_type\": \"BRD\",\n  \"output_format\": \"Word (.docx)\",\n  \"document_ids\": [\n    \"{{document_id}}\"\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Has project_id', () => pm.expect(json).to.have.property('project_id'));",
                  "if (json.project_id) {",
                  "  pm.collectionVariables.set('project_id', json.project_id);",
                  "  console.log('Saved project_id:', json.project_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Project — Validation Error (422)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects",
            "description": "Intentionally missing required fields. Expect 422 with field-level errors.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_name\": \"Incomplete Project\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422 for missing fields', () => pm.response.to.have.status(422));",
                  "const json = pm.response.json();",
                  "pm.test('Has fields array', () => pm.expect(json).to.have.property('fields'));",
                  "console.log('Validation errors:', JSON.stringify(json.fields, null, 2));"
                ]
              }
            }
          ]
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "projects"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "",
                  "disabled": true,
                  "description": "Search by name or code"
                },
                {
                  "key": "status",
                  "value": "",
                  "disabled": true,
                  "description": "draft | ready | generating | completed"
                }
              ]
            },
            "description": "List all projects. Enable query params to filter."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has projects array', () => pm.expect(pm.response.json()).to.have.property('projects'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Project (Full)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/{{project_id}}",
            "description": "Get full project including all fields, stakeholders, doc IDs."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Correct project', () => pm.expect(pm.response.json().project_id).to.eql(pm.collectionVariables.get('project_id')));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Project (PUT — full)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/projects/{{project_id}}",
            "description": "Full update. Send all fields you want to change.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"business_priority\": \"Critical\",\n  \"estimated_cost_crores\": \"5.2\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has updated_at', () => pm.expect(pm.response.json()).to.have.property('updated_at'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Patch Project (PATCH — partial / autosave)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/projects/{{project_id}}",
            "description": "Partial update — send only fields that changed.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"end_date\": \"2026-03-31\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Project Data (Ingested + Derived)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/{{project_id}}/data",
            "description": "Returns both ingested (15 fields) and derived (12 AI fields) in one call. Use for Project Details page."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has ingested', () => pm.expect(json).to.have.property('ingested'));",
                  "pm.test('Has derived',  () => pm.expect(json).to.have.property('derived'));",
                  "console.log('Ingested fields:', Object.keys(json.ingested).join(', '));",
                  "console.log('Derived fields:', Object.keys(json.derived).join(', '));"
                ]
              }
            }
          ]
        },
        {
          "name": "Save Ingested Changes (Tab 1)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/projects/{{project_id}}/data/ingested",
            "description": "Save user edits to the 15 ingested fields. Called on Save button in Tab 1.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_name\": \"Smart Meter Analytics v2\",\n  \"business_priority\": \"Highly Critical\",\n  \"estimated_cost_crores\": \"5.0\",\n  \"stakeholders\": [\n    {\n      \"name\": \"Srinivas Gutta\",\n      \"designation\": \"Project Manager\"\n    },\n    {\n      \"name\": \"Ali Imam\",\n      \"designation\": \"Technical Lead\"\n    },\n    {\n      \"name\": \"Rajesh Lad\",\n      \"designation\": \"Business Analyst\"\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Run AI Derive Fields",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects/{{project_id}}/derive-fields",
            "description": "AI generates all 12 derived fields from project data + documents. Takes 30-60s.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has fields_populated', () => pm.expect(json).to.have.property('fields_populated'));",
                  "console.log('Fields populated by AI:', json.fields_populated);"
                ]
              }
            }
          ]
        },
        {
          "name": "Save Derived Changes (Tab 2)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/projects/{{project_id}}/data/derived",
            "description": "Save user edits to the 12 AI-derived fields. Called on Save button in Tab 2.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"success_criteria\": \"Reduce manual meter reading by 90%. Real-time billing accuracy above 99%.\",\n  \"current_challenges\": \"Manual errors in billing. 15-day lag in consumption data.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/projects/{{project_id}}",
            "description": "Permanently delete a project and its derived data. Returns 204."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
