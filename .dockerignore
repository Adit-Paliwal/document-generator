# Keep the build context small and secret-free
.git
.gitignore
*.md
*.zip
*.xlsx
*.docx
*.postman_collection.json

# Python noise
**/__pycache__/
**/*.pyc
env/
.venv/
*.egg-info/

# Node — the image rebuilds the frontend in stage 1
frontend-react/node_modules/
frontend-react/dist/

# Local data / secrets — never bake these into the image
Data_Ingestion/local_storage/
Data_Ingestion/.env
# NOTE: key.json is mounted at runtime via docker-compose (not copied in)

# Test + scratch
Data_Ingestion/tests/__pycache__/
.claude/
