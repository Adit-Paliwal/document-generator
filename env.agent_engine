# ── Runtime environment variables for the deployed Agent Engine container ──
# This file is passed via --env_file when running adk deploy agent_engine.
#
# DO NOT add:
#   GOOGLE_CLOUD_PROJECT  ← reserved by GCP, auto-set at runtime
#   GOOGLE_CLOUD_LOCATION ← reserved by GCP, auto-set at runtime
#   GEMINI_API_KEY        ← not needed; agent uses ADC (gcloud auth)
#
MODEL_PROVIDER=gemini
LOCAL_MODE=true
LOCAL_DB=true
INTELLIDRAFT_DB_DIR=/tmp/intellidraft
ASYNC_GENERATION=false
VISION_ENABLED=true
PYTHONUTF8=1
