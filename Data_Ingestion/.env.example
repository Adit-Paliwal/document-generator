# ═══════════════════════════════════════════════════════════════
# Document Generator — Environment Variables Template
# -------------------------------------------------------
# COPY THIS FILE to .env and fill in your actual values.
# NEVER commit .env to git — it is in .gitignore.
# ═══════════════════════════════════════════════════════════════

# ── LLM Provider Strategy ──────────────────────────────────────
# Gemini is the PRIMARY provider for ALL operations (extract, derive-fields,
# document generation). Azure GPT-5 is the automatic FALLBACK — used only
# when Gemini credentials are absent or a Gemini call fails.
# Supported values: gemini | azure_gpt5
MODEL_PROVIDER=gemini

# ── Local / Cloud Storage Mode ─────────────────────────────────
# true  = saves to ./local_storage/ (no Azure needed)
# false = saves to Azure Blob + Cosmos DB
LOCAL_MODE=true

# ── Google Gemini (PRIMARY LLM) ───────────────────────────────
#
# Option A — API Key  (easiest for local dev)
#   Get a free key at: https://aistudio.google.com/app/apikey
#   Either variable name is accepted (GEMINI_API_KEY takes precedence):
GEMINI_API_KEY=          # recommended name
GOOGLE_API_KEY=          # alternative name — same key, either works

# Option B — Vertex AI  (enterprise / production)
#   Authentication via GCP service account JSON key file.
#   Place the file at Data_Ingestion/key.json  (already in .gitignore).
#   OR set a custom path below (leave blank to use the default):
#
#   ⚠ WINDOWS PATH WARNING: dotenv expands backslash sequences — \a → bell char,
#   \n → newline, \t → tab, etc.  Always use forward slashes OR double backslashes:
#     CORRECT:   GOOGLE_KEY_JSON_PATH=C:/Users/you/project/key.json
#     CORRECT:   GOOGLE_KEY_JSON_PATH=C:\\Users\\you\\project\\key.json
#     BROKEN:    GOOGLE_KEY_JSON_PATH=C:\Users\you\project\key.json  ← \y is fine but
#                  \a, \b, \f, \n, \r, \t, \v will be silently replaced by control chars
#
GOOGLE_KEY_JSON_PATH=    # blank = default Data_Ingestion/key.json

# Vertex AI region — us-central1 works for all Gemini models
VERTEX_LOCATION=us-central1

# Gemini model (used by both Option A and Option B).
# Stable GA (recommended):   gemini-2.5-flash  (default — 1M context, fast)
# Higher quality / slower:   gemini-2.5-pro
# DO NOT USE:                gemini-1.0-pro    (deprecated Feb 2025)
GEMINI_VERTEX_MODEL=gemini-2.5-flash

# ══════════════════════════════════════════════════════════════
# AZURE GPT-5
# ══════════════════════════════════════════════════════════════
AZURE_GPT5_MODEL_DEPLOYMENT_ID=your-gpt5-deployment-name
AZURE_GPT5_OPENAI_API_KEY=your_azure_gpt5_api_key_here
AZURE_GPT5_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_GPT5_API_VERSION=2024-12-01-preview
AZURE_GPT5_MODEL_NAME=gpt-5

# ── Azure OpenAI (generic — for other deployments) ─────────────
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Database ───────────────────────────────────────────────────
# true  = SQLite (dev default — file auto-created at INTELLIDRAFT_DB_DIR)
# false = SQL DB via DATABASE_URL (production)
LOCAL_DB=true

# Override SQLite directory — USE THIS if your project is inside OneDrive / Dropbox.
# SQLite WAL-mode databases must NOT live in cloud-synced folders.
# Leave blank to use the auto-detected safe path (%LOCALAPPDATA%\Intellidraft on Windows).
INTELLIDRAFT_DB_DIR=    # e.g. C:\dev\intellidraft_db

# Production DB connection string (only used when LOCAL_DB=false):
# Azure SQL:   mssql+pyodbc://user:pass@host/db?driver=ODBC+Driver+18+for+SQL+Server
# PostgreSQL:  postgresql+psycopg2://user:pass@host/db
DATABASE_URL=

# ── Generation ─────────────────────────────────────────────────
# true  = generate in background thread (client polls) — recommended for prod
# false = generate synchronously inside HTTP request  — use for debugging
ASYNC_GENERATION=true

# ── LibreOffice Preview (async document-to-HTML conversion) ───
# true  = Celery + Redis async mode (production — requires celery-worker container)
# false = synchronous fallback (local dev, no Redis or worker needed)
CELERY_ENABLED=false

# Redis connection string — used as Celery broker, result backend, and preview cache
# Local Docker: redis://localhost:6379/0
# Azure Cache for Redis: rediss://:password@host.redis.cache.windows.net:6380/0
REDIS_URL=redis://localhost:6379/0

# How long to keep a rendered HTML preview in Redis cache (seconds, default 1 hour)
PREVIEW_CACHE_TTL=3600

# LibreOffice conversion timeout in seconds per document (default 90s)
LO_CONVERT_TIMEOUT=90

# ── Vision AI ──────────────────────────────────────────────────
# true  = images sent to LLM for AI description
# false = images stored as-is, no description generated
VISION_ENABLED=true

# ── Azure Storage (only used when LOCAL_MODE=false) ────────────
AZURE_BLOB_ACCOUNT_URL=https://youraccount.blob.core.windows.net
AZURE_BLOB_CONTAINER=doc-processor
AZURE_COSMOS_URL=https://youraccount.documents.azure.com:443
AZURE_COSMOS_DB=docprocessor
AZURE_COSMOS_CONTAINER=documents
AZURE_KEYVAULT_URL=https://your-kv.vault.azure.net
GCP_SA_SECRET_NAME=gcp-gemini-sa-key
