  "BRD": [
    {
      "section": "Purpose",
      "description": "Explain what the project/product/agent/tool is, what it will do, and how the current process works.",
      "variables": "Project/Product overview",
      "format": "Text",
      "remarks": "Use user input only for actual content.",
      "depth": "Detailed"
    },
    {
      "section": "Scope",
      "description": "Define lifecycle, coverage, scale, and what issue the project is solving.",
      "variables": "Scope, lifecycle, scale",
      "format": "Text/List",
      "remarks": "Mention in-scope and out-of-scope if available.",
      "depth": "Detailed"
    },
    {
      "section": "Business Use Cases",
      "description": "Capture key business scenarios supported by the solution.",
      "variables": "Use Case #, Name, Trigger Event, Primary Actor, Secondary Actor, Main Action, Expected Outcome, Exception",
      "format": "Table",
      "remarks": "Generate UC1, UC2 etc. from input.",
      "depth": "Detailed"
    },
    {
      "section": "Business Requirement",
      "description": "List business needs with tracking number, phase, priority, rationale, stakeholders, and remarks.",
      "variables": "Requirement Number, Phase, Priority, Description, Rationale, Impacted Stakeholders, Remarks",
      "format": "Table",
      "remarks": "Requirement IDs like BRQ-001.",
      "depth": "Detailed"
    },
    {
      "section": "Functional Requirement",
      "description": "Define system features/capabilities required to satisfy business needs.",
      "variables": "Requirement Number, Sr., Description, Rationale, Solution Overview, Remarks",
      "format": "Table",
      "remarks": "Requirement IDs like FR-001.",
      "depth": "Detailed"
    },
    {
      "section": "Non-Functional Requirement",
      "description": "Define performance, security, operational, installation, procedural, compatibility constraints.",
      "variables": "Performance, Security, Operational, Installation, Procedural, Flexibility & Compatibility",
      "format": "Table/List",
      "remarks": "Include NFR constraints from project input.",
      "depth": "Detailed"
    },
    {
      "section": "Cloud-First Architecture",
      "description": "Describe cloud platform, ingestion, storage, processing, infrastructure, and medallion layers.",
      "variables": "Cloud Platform, Data Ingestion, Bronze/Silver/Gold, Processing Engine, Infrastructure",
      "format": "Text/List",
      "remarks": "Applicable for cloud/data/AI projects.",
      "depth": null
    },
    {
      "section": "Algorithms & Development Stack",
      "description": "List AI/ML, data engineering, web app, dashboarding, and CI/CD technology stack.",
      "variables": "Algorithms/AI, Data Engineering, Web Application, Visualization, CI/CD",
      "format": "Text/List",
      "remarks": "Use only if relevant.",
      "depth": null
    },
    {
      "section": "Project Schedule",
      "description": "Capture project gates and tentative timelines.",
      "variables": "PI Gate, PC Gate, VR Gate, UATR, RO Gate, PCD Gate",
      "format": "Table",
      "remarks": "Dates can be tentative.",
      "depth": "Detailed"
    },
    {
      "section": "Other Constraints and Assumptions",
      "description": "List dependencies, assumptions, internal support needs, risks, and constraints.",
      "variables": "Dependency, Assumption, Risk, Owner, Remarks",
      "format": "Table/List",
      "remarks": "Include IT support, infra, approval dependencies.",
      "depth": null
    },
    {
      "section": "Business Requirement Summary",
      "description": "Summarize business need, problem statement, vision, goals, and proposed solution.",
      "variables": "Business Need, Problem Statement, Vision, Goals, Proposed Solution",
      "format": "Text",
      "remarks": "Executive-style summary.",
      "depth": "Detailed"
    },
    {
      "section": "Business Value Delivered",
      "description": "Describe tangible benefits such as savings, automation, efficiency, consistency, auditability.",
      "variables": "Business Value, Benefits Derived, Value Category",
      "format": "Text/List",
      "remarks": "Mention quantification if user provides numbers.",
      "depth": null
    },
    {
      "section": "Competitor Landscape",
      "description": "Describe similar tools, current solutions, market gaps, and platform positioning.",
      "variables": "Current Tools, Similar Solutions, Market Gaps, Positioning",
      "format": "Text/List",
      "remarks": "Optional if data is available.",
      "depth": "Detailed"
    },
    {
      "section": "Critical Success Factors",
      "description": "List major success enablers for platform/project success.",
      "variables": "Sponsorship, KPI, Governance, Architecture, Models, MLOps, Enablement",
      "format": "List",
      "remarks": "Useful for digital/platform projects.",
      "depth": null
    },
    {
      "section": "Business Process",
      "description": "Explain current business process, pain areas, opportunities, and technology gaps.",
      "variables": "Current Process, Pain Areas, Tech Gaps, Opportunities",
      "format": "Text/List",
      "remarks": "Use As-Is/To-Be where possible.",
      "depth": "Short"
    },
    {
      "section": "Business Process Impacted",
      "description": "Describe As-Is and To-Be process and expected business impact.",
      "variables": "As-Is Process, To-Be Process, Positive Outcomes",
      "format": "Text/List",
      "remarks": "Mention systems/data sources impacted.",
      "depth": "Short"
    }
  ],
