# ═══════════════════════════════════════
# IntelliDraft — .gitignore
# ═══════════════════════════════════════

# ── CRITICAL: Never commit secrets ──────
.env
.env.local
.env.production
Data_Ingestion/.env
Data_Ingestion/agent/.env
*.key
*.pem
*.pfx
secrets/
# GCP service account key — contains private key, must never be committed
Data_Ingestion/key.json
key.json

# ── Python ──────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ─────────────────
env/
venv/
.venv/
ENV/
env.bak/

# ── Local database & storage ─────────────
Data_Ingestion/local_storage/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── IDE & OS ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
*.bak

# ── Azure Functions ───────────────────────
.azure/
local.settings.json
bin/
obj/

# ── Node (frontend) ───────────────────────
node_modules/
dist/
.next/
.nuxt/
.cache/
*.log
npm-debug.log*
yarn-error.log*

# ── Jupyter ───────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Test artifacts ────────────────────────
htmlcov/
.coverage
coverage.xml
*.cover

# ── Temporary files ───────────────────────
*.tmp
*.temp
tmp/
temp/

# ── Microsoft Office lock files ───────────
~$*

# ── ADK session state ─────────────────────
.adk/

# ── Claude Code session memory (local only) ──
.claude/

# ── Archives ──────────────────────────────
*.zip

# ── GCP / Cloud deployment artefacts ──────
# Agent Engine staging uploads (auto-generated by Vertex AI SDK)
Data_Ingestion/*.egg-info/
Data_Ingestion/dist/
Data_Ingestion/build/
*.egg-info/
# Cloud Run / Cloud Build
.gcloudignore

# Vite dev cache
frontend-react/.vite/
